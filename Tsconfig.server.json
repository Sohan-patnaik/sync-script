{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2017",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server/**/*.ts"]
}